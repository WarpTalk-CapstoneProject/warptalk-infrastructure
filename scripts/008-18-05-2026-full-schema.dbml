  credits_used_this_cycle INT [not null]
  snapshot_at TIMESTAMPTZ [not null, default: `NOW()`]
}

Table subscription.usage_records {
  id UUID [primary key, default: `uuid_generate_v7()`]
  subscription_id UUID [not null]
  user_id UUID [not null, note: 'External AuthService user id. No physical FK.']
  workspace_id UUID [note: 'External AuthService workspace id. No physical FK.']
  translation_room_id UUID [note: 'External TranslationRoomService room id. No physical FK.']
  usage_type VARCHAR(30) [not null]
