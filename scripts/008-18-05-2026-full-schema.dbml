Project WarpTalk {
  database_type: 'PostgreSQL'
  Note: '''
  WarpTalk Microservices Data Model.

  This is a logical, service-owned data model for a microservice architecture.
  Each service owns its own schema and controls its data through APIs/events.
  Physical foreign keys are only defined inside the same service-owned schema.

  Cross-service identifiers such as user_id, workspace_id, translation_room_id,
  transcript_id, subscription_id, and notification_id are stored as external
  business references for traceability, not as runtime database foreign keys.

  Cross-service consistency is handled through service APIs, domain events,
  idempotency keys, outbox/inbox patterns, and eventual consistency.

  PostgreSQL stores structured service data. Qdrant stores vector embeddings
  for transcript semantic search, meeting memory retrieval, AI assistant Q&A,
  and glossary matching. PostgreSQL keeps metadata and Qdrant point references.
  '''
}

Enum room_status {
  SCHEDULED
  WAITING
  IN_PROGRESS
  PAUSED
  ENDED
  CANCELLED
  EXPIRED
  FAILED
}

Enum participant_status {
  INVITED
  WAITING
  CONNECTED
  DISCONNECTED
  LEFT
  KICKED
  REJECTED
}

Enum job_status {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

Enum consent_status {
  GRANTED
  REVOKED
  EXPIRED
}

Enum artifact_type {
  TRANSCRIPT_EXPORT
  SUMMARY_EXPORT
  DEBUG_LOG
  OPTIONAL_RECORDING
  AUDIO_SAMPLE
}

Enum notification_status {
  PENDING
  SENT
  DELIVERED
  FAILED
  READ
}

Enum ticket_status {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

Enum transcript_status {
  RECORDING
  FINALIZING
  FINALIZED
  ARCHIVED
}

Enum correction_status {
  PENDING
  ACCEPTED
  REJECTED
}

Enum correction_type {
  STT
  TRANSLATION
}

Enum meeting_status {
  CREATED
  ACTIVE
  FINISHED
}

Enum media_type {
  AUDIO
  VIDEO
}

TableGroup AuthService {
  auth.users
  auth.roles
  auth.permissions
  auth.role_permissions
  auth.user_roles
  auth.refresh_tokens
  auth.user_settings
  auth.workspaces
  auth.workspace_members
  auth.workspace_invitations
  auth.schema_migrations
}

TableGroup MeetingService {
  meeting.meeting_rooms
  meeting.meeting_participants
  meeting.meeting_tracks
  meeting.schema_migrations
}

TableGroup TranslationRoomService {
  translation_room.translation_rooms
