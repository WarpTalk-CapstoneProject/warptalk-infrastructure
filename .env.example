# ====================================================================
# WarpTalk Infrastructure — Environment Variables
# Copy to .env and fill in real values
# ====================================================================

# ── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_DB=warptalk
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<GENERATE_SECURE_PASSWORD>

# ── Per-Service DB Users ─────────────────────────────────────────────
AUTH_DB_PASSWORD=<GENERATE_SECURE_PASSWORD>
MEETING_DB_PASSWORD=<GENERATE_SECURE_PASSWORD>
TRANSCRIPT_DB_PASSWORD=<GENERATE_SECURE_PASSWORD>
SUBSCRIPTION_DB_PASSWORD=<GENERATE_SECURE_PASSWORD>
NOTIFICATION_DB_PASSWORD=<GENERATE_SECURE_PASSWORD>

# ── Redis ────────────────────────────────────────────────────────────
REDIS_PASSWORD=<GENERATE_SECURE_PASSWORD>

# ── JWT ──────────────────────────────────────────────────────────────
JWT_SECRET=<GENERATE_SECURE_PASSWORD_MIN_64_CHARS>
JWT_ISSUER=WarpTalk.AuthService
JWT_AUDIENCE=WarpTalk

# ── COTURN (TURN/STUN) ──────────────────────────────────────────────
TURN_SECRET=<GENERATE_SECURE_PASSWORD>
TURN_REALM=warptalk.vn

# ── CORS ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://warptalk.vn

# ── Observability ────────────────────────────────────────────────────
SEQ_API_KEY=
GRAFANA_ADMIN_PASSWORD=<GENERATE_SECURE_PASSWORD>

# ── Backup (S3/MinIO) ───────────────────────────────────────────────
BACKUP_S3_BUCKET=warptalk-backups
BACKUP_S3_ENDPOINT=http://minio:9000
BACKUP_S3_ACCESS_KEY=<GENERATE_SECURE_PASSWORD>
BACKUP_S3_SECRET_KEY=<GENERATE_SECURE_PASSWORD>
