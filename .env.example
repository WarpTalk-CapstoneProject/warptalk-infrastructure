# ====================================================================
# WarpTalk Infrastructure — Environment Variables
# Copy to .env and fill in real values
# ====================================================================

# ── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_DB=warptalk
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Per-Service DB Users ─────────────────────────────────────────────
AUTH_DB_PASSWORD=auth_secret_password
MEETING_DB_PASSWORD=meeting_secret_password
TRANSCRIPT_DB_PASSWORD=transcript_secret_password
SUBSCRIPTION_DB_PASSWORD=subscription_secret_password
NOTIFICATION_DB_PASSWORD=notification_secret_password

# ── Redis ────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── JWT ──────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_SUPER_SECRET_KEY_MIN_32_CHARS_LONG!!
JWT_ISSUER=WarpTalk.AuthService
JWT_AUDIENCE=WarpTalk

# ── COTURN (TURN/STUN) ──────────────────────────────────────────────
TURN_SECRET=CHANGE_ME_TURN_SECRET
TURN_REALM=warptalk.vn

# ── CORS ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://warptalk.vn

# ── Observability ────────────────────────────────────────────────────
SEQ_API_KEY=
GRAFANA_ADMIN_PASSWORD=admin

# ── Backup (S3/MinIO) ───────────────────────────────────────────────
BACKUP_S3_BUCKET=warptalk-backups
BACKUP_S3_ENDPOINT=http://minio:9000
BACKUP_S3_ACCESS_KEY=minioadmin
BACKUP_S3_SECRET_KEY=minioadmin
